# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable dev login bypass (set to "true" in local dev only, NEVER in production)
ENABLE_DEV_LOGIN=false

# ─── Firebase (Client SDK – public) ──────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (Server – private) ───────────────────────────────────
# Option A: base64-encoded service account JSON (recommended for Vercel)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option B: individual fields (alternative to base64)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option A: single connection string (used by migrate script and app)
DATABASE_URL=

# Option B: Cloud SQL (Google Cloud)
CLOUD_SQL_INSTANCE_CONNECTION_NAME=

# Option C: direct TCP (individual fields)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=post_sales
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# ─── HubSpot ──────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=

# ─── Account brief (AI + optional Marketing Mind / WhatsApp APIs) ─────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MARKETING_MIND_API_URL=
MARKETING_MIND_API_KEY=
MARKETING_MIND_FEATURES_URL_TEMPLATE=
WHATSAPP_CAMPAIGNS_API_URL=
WHATSAPP_CAMPAIGNS_API_KEY=
WHATSAPP_CAMPAIGNS_URL_TEMPLATE=

# ─── Auth domains (comma-separated; leave empty to allow all) ─────────────────
ALLOWED_EMAIL_DOMAINS=

# ─── Cron secret (used by Vercel cron to authenticate sync endpoint) ──────────
CRON_SECRET=
