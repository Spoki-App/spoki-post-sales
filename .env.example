# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable dev login bypass (set to "true" in local dev only, NEVER in production)
ENABLE_DEV_LOGIN=false

# ─── Firebase (Client SDK – public) ──────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (Server – private) ───────────────────────────────────
# Option A: base64-encoded service account JSON (recommended for Vercel)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option B: individual fields (alternative to base64)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option A: single connection string (used by migrate script and app)
DATABASE_URL=

# Option B: Cloud SQL (Google Cloud)
CLOUD_SQL_INSTANCE_CONNECTION_NAME=

# Option C: direct TCP (individual fields)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=post_sales
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# ─── AI Provider (claude | gemini) ─────────────────────────────────────────────
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Google AI (Gemini, fallback) ──────────────────────────────────────────────
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── HubSpot ──────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=
# Comma-separated workflow IDs to show in the enrollment modal (leave empty to show all)
HUBSPOT_WORKFLOW_ALLOWLIST=

# ─── Account brief (AI + optional Marketing Mind / WhatsApp APIs) ─────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MARKETING_MIND_API_URL=
MARKETING_MIND_API_KEY=
MARKETING_MIND_FEATURES_URL_TEMPLATE=
WHATSAPP_CAMPAIGNS_API_URL=
WHATSAPP_CAMPAIGNS_API_KEY=
WHATSAPP_CAMPAIGNS_URL_TEMPLATE=

# ─── Auth domains (comma-separated; leave empty to allow all) ─────────────────
ALLOWED_EMAIL_DOMAINS=

# ─── Metabase (dashboard data integration) ────────────────────────────────────
METABASE_URL=https://metabase.spoki.com
METABASE_API_KEY=
METABASE_DATABASE_ID=2

# ─── Stripe (failed payments detection) ───────────────────────────────────────
STRIPE_API_KEY=

# ─── Cron secret (used by Vercel cron to authenticate sync endpoint) ──────────
CRON_SECRET=

# ─── Gmail (QBR email sending) ────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Google Chat (QBR: space release) ─────────────────────────────────────────
# Space delle release (nome risorsa API).
GOOGLE_CHAT_RELEASE_SPACE_ID=spaces/AAQAXowZpvE

# Opzione A — App Chat + service account (membro dello space):
# GOOGLE_CHAT_SERVICE_ACCOUNT_BASE64=
# GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=

# Opzione B — OAuth utente (l'account autorizzato deve essere nello space). Client OAuth da GCP
# con scope https://www.googleapis.com/auth/chat.messages.readonly; ottieni refresh_token una volta
# (es. OAuth 2.0 Playground con scope Chat, o flusso authorization code).
# GOOGLE_CHAT_OAUTH_CLIENT_ID=
# GOOGLE_CHAT_OAUTH_CLIENT_SECRET=
# GOOGLE_CHAT_OAUTH_REFRESH_TOKEN=
